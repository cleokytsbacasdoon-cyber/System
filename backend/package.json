{
  "name": "ml-monitoring-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:init": "node src/scripts/initDb.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "ml:install": "python -m pip install -r src/scripts/ml/requirements.txt",
    "ml:train": "python src/scripts/ml/train_tourism.py"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
