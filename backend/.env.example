PORT=3000

# Option 1: full connection string
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/ml_monitoring

# Option 2: discrete settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ml_monitoring
DB_USER=postgres
DB_PASSWORD=postgres

# ML model integration
# local: run Python XGBoost model from backend/models
# colab: call a hosted prediction endpoint
ML_MODEL_SOURCE=local
ML_MODEL_DIR=./models
ML_MODEL_FILE=./models/tourism_xgb_model.json
ML_MODEL_METADATA_FILE=./models/tourism_model_metadata.json
PYTHON_BIN=python
# ML_COLAB_PREDICT_URL=https://your-colab-endpoint/predict

# Holiday API integration
# Used only when requested month/year is not already covered in monthly_tourism_dataset.
CALENDARIFIC_API_KEY=
